<section id="contact" class="section">
    <div class="max-width" style="max-width: 600px;">
        <h2 class="section-title">Get In Touch</h2>
        <p style="text-align: center; color: #a1a1aa; margin-bottom: 40px;">
            Feel free to reach out for opportunities or just to chat about code.
        </p>
        
        <form action="/contact" method="POST" style="display: flex; flex-direction: column; gap: 20px;">
            <input type="text" name="name" placeholder="Your Name" required class="form-input">
            <input type="email" name="email" placeholder="Your Email" required class="form-input">
            <textarea name="message" rows="6" placeholder="Your Message" required class="form-input"></textarea>
            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 16px;">Send Message</button>
        </form>
    </div>
</section>